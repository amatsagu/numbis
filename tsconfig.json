{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", 
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "contents/src",
    "baseUrl": ".",
    "lib": ["ESNext"]
  },
  "include": ["src/**/*.ts"]
}